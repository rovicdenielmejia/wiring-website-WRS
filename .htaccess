# Clean URLs: serve .html at extensionless paths, redirect .html to clean
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # If request has .html, redirect to clean URL (301)
    RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
    RewriteRule ^ /%1 [R=301,L,NE]

    # If request is for a path that has no extension, try .html
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^(.+)$ $1.html [L]
</IfModule>
